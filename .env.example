# ─── AUTH ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local dev: mongodb://localhost:27017/worldcup26
# Railway:   provided automatically as MONGODB_URL
MONGODB_URI=mongodb://localhost:27018/worldcup26
# ─── REDIS ────────────────────────────────────────────────────────────────────
# Get from: upstash.com → Create Redis → copy REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# For Express server (ioredis) — same Redis instance, use Upstash TLS URL
REDIS_URL=rediss://default:password@your-upstash-endpoint:6379

# ─── EMAIL (MAGIC LINKS) ──────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@worldcup26.com

# ─── FOOTBALL API ─────────────────────────────────────────────────────────────
# Get from: api-football.com → Dashboard → API Key
# Free tier: 100 req/day (enough for dev)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ─── AI ───────────────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── WEB SEARCH (AI agent) ────────────────────────────────────────────────────
# Get from: app.tavily.com → API Keys (free: 1000 searches/mo)
TAVILY_API_KEY=

# ─── INTERNAL SERVICES ────────────────────────────────────────────────────────
# Random string — protects /api/cron/* routes from public calls
CRON_SECRET=

# Used by Python agent to call Next.js internal APIs
INTERNAL_API_KEY=

# Railway service URLs (set in Railway dashboard, leave empty for local dev)
RAILWAY_EXPRESS_URL=http://localhost:4000
RAILWAY_AGENT_URL=http://localhost:8000
MCP_SERVER_URL=http://localhost:5000

# ─── DEPLOYMENT ───────────────────────────────────────────────────────────────
# Vercel project ID (auto-set by Vercel)
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

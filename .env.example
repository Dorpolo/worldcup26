# ─── AUTH ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# docker-compose overrides this to mongodb://mongo:27017/worldcup26
MONGODB_URI=mongodb://localhost:27017/worldcup26

# ─── REDIS ────────────────────────────────────────────────────────────────────
# docker-compose overrides this to redis://redis:6379
REDIS_URL=redis://localhost:6379

# ─── EMAIL (MAGIC LINKS) ──────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@worldcup26.com

# ─── FOOTBALL API ─────────────────────────────────────────────────────────────
# Get from: api-football.com → Dashboard → API Key
# Free tier: 100 req/day (enough for dev); Basic ~$10/mo for production
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ─── AI ───────────────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── WEB SEARCH (AI agent) ────────────────────────────────────────────────────
# Get from: app.tavily.com → API Keys (free: 1000 searches/mo)
TAVILY_API_KEY=

# ─── INTERNAL SERVICES ────────────────────────────────────────────────────────
# Random string — protects /api/cron/* routes from public calls
# Generate: openssl rand -hex 32
CRON_SECRET=

# Shared secret for agent/MCP → Next.js internal API calls (bypasses session auth)
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=

# ─── SERVICE URLS ─────────────────────────────────────────────────────────────
# docker-compose overrides these with internal service names (http://mcp:4001 etc.)
RAILWAY_EXPRESS_URL=http://localhost:4000
RAILWAY_AGENT_URL=http://localhost:8000
MCP_SERVER_URL=http://localhost:4001

# ─── LANGSMITH (optional AI tracing) ──────────────────────────────────────────
# Get from: smith.langchain.com → Settings → API Keys
# Leave blank to disable tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=worldcup26

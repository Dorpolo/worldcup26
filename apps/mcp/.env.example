# MongoDB — same connection string as the Next.js app
MONGODB_URI=mongodb://localhost:27017/worldcup26

# The shared internal API key — same value as INTERNAL_API_KEY in apps/web/.env.local
INTERNAL_API_KEY=

# URL of the Next.js app (MCP server proxies tool calls here)
NEXTAUTH_URL=http://localhost:3000

# Port this MCP server listens on
PORT=4001
